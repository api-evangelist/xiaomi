          "name": "Create Chat Completion",
          "request": {
            "name": "Create Chat Completion",
            "description": {
              "content": "Creates a chat completion response from the specified MiMo model. The API is OpenAI-compatible and supports streaming, function calling, and multi-turn conversations. Available models include mimo-v2.5-pro, mimo-v2.5, mimo-v2-pro, mimo-v2-omni, mimo-v2-flash, and TTS variants.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "chat",
                "completions"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },

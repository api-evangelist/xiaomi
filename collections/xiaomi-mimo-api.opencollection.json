{
  "opencollection": "1.0.0",
  "info": {
    "name": "Xiaomi MiMo AI API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "api-key",
      "value": "{{api-key}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Chat",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create Chat Completion",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.xiaomimimo.com/v1/chat/completions",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a chat completion response from the specified MiMo model. The API is OpenAI-compatible and supports streaming, function calling, and multi-turn conversations. Available models include mimo-v2.5-pro, mimo-v2.5, mimo-v2-pro, mimo-v2-omni, mimo-v2-flash, and TTS variants."
        }
      ]
    },
    {
      "info": {
        "name": "Models",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Models",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.xiaomimimo.com/v1/models"
          },
          "docs": "Returns a list of available MiMo AI models with their IDs and capabilities."
        }
      ]
    }
  ],
  "bundled": true
}